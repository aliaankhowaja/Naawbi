<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:id="rootPane"
           fx:controller="naawbi.controller.CreateAssignmentController"
           prefWidth="1920" prefHeight="1080"
           styleClass="root-pane"
           stylesheets="@./CreateAssignmentView.css">
    <HBox alignment="CENTER" spacing="0" prefWidth="1920" prefHeight="1080">
        <VBox alignment="CENTER" spacing="0" prefWidth="860" HBox.hgrow="ALWAYS">
            <VBox styleClass="form-container" spacing="0">
                <!-- Form header -->
                <VBox spacing="8" styleClass="form-header">
                    <Label text="Create Assignment" styleClass="form-title" />
                    <Label text="Fill in the assignment details below: description is optional but recommended."
                           styleClass="form-subtitle" wrapText="true" />
                </VBox>
                <!-- Divider: use Pane instead of Rectangle to support maxWidth -->
                <Pane styleClass="form-divider" prefHeight="1" maxHeight="1" minHeight="1" />
                <!-- Form body -->
                <VBox spacing="32" styleClass="form-body">
                    <!-- Title field -->
                    <VBox spacing="8">
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label text="Title" styleClass="field-label" />
                            <Label text="*" styleClass="required-mark" />
                        </HBox>
                        <TextField fx:id="titleField"
                                   promptText="e.g. Essay on Climate Change"
                                   styleClass="text-field-modern" />
                        <Label fx:id="titleError" text="" styleClass="field-error" managed="false" visible="false" />
                    </VBox>
                    <!-- Description field -->
                    <VBox spacing="8">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="Description" styleClass="field-label" />
                            <Label text="Optional" styleClass="optional-badge" />
                        </HBox>
                        <TextArea fx:id="descriptionField"
                                  promptText="Briefly describe the assignment requirements and what students should submit..."
                                  styleClass="text-area-modern"
                                  prefRowCount="3"
                                  wrapText="true" />
                    </VBox>
                    <!-- Deadline date field -->
                    <VBox spacing="8">
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Label text="Deadline" styleClass="field-label" />
                            <Label text="*" styleClass="required-mark" />
                        </HBox>
                        <DatePicker fx:id="deadlineDate"
                                    styleClass="date-picker-modern"
                                    promptText="Select deadline date" />
                        <Label fx:id="deadlineError" text="" styleClass="field-error" managed="false" visible="false" />
                    </VBox>
                    <!-- Deadline time fields -->
                    <VBox spacing="8">
                        <Label text="Time" styleClass="field-label" />
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <!-- Hour spinner -->
                            <VBox spacing="6">
                                <Label text="Hour (0-23)" styleClass="time-field-label" />
                                <Spinner fx:id="deadlineHour"
                                         min="0" max="23" initialValue="23"
                                         styleClass="spinner-modern"
                                         prefWidth="120" />
                            </VBox>
                            <!-- Minute spinner -->
                            <VBox spacing="6">
                                <Label text="Minute (0-59)" styleClass="time-field-label" />
                                <Spinner fx:id="deadlineMinute"
                                         min="0" max="59" initialValue="59"
                                         styleClass="spinner-modern"
                                         prefWidth="120" />
                            </VBox>
                        </HBox>
                    </VBox>
                    <!-- Publish toggle row -->
                    <HBox spacing="16" alignment="CENTER_LEFT" styleClass="toggle-row">
                        <CheckBox fx:id="publishToggle" styleClass="modern-checkbox" />
                        <VBox spacing="2">
                            <Label text="Publish immediately" styleClass="toggle-label" />
                            <Label text="Students can view and submit as soon as this assignment is created"
                                   styleClass="toggle-sublabel" />
                        </VBox>
                    </HBox>
                </VBox>
                <!-- Divider: use Pane instead of Rectangle -->
                <Pane styleClass="form-divider" prefHeight="1" maxHeight="1" minHeight="1" />
                <!-- Action row -->
                <HBox styleClass="form-actions" alignment="CENTER_RIGHT" spacing="16">
                    <Label fx:id="globalError" text="" styleClass="global-error" managed="false" visible="false" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="cancelBtn" text="Cancel" styleClass="btn-secondary"
                            onAction="#handleCancel" />
                    <Button fx:id="createBtn" text="Create Assignment →" styleClass="btn-primary"
                            defaultButton="true" onAction="#handleCreate" />
                </HBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
