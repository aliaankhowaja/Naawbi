<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:id="rootPane"
           fx:controller="naawbi.controller.AssignmentDetailsController"
           prefWidth="800" prefHeight="700"
           style="-fx-background-color: -vc-background;">
    
    <VBox spacing="16" alignment="TOP_CENTER" style="-fx-padding: 32; -fx-background-color: -vc-background;">
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel" text="Assignment Title" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -vc-text;" />
                <Label fx:id="courseContextLabel" text="Course / Instructor" style="-fx-font-size: 14px; -fx-text-fill: gray;" />
            </VBox>
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="pointsLabel" text="100 Points" style="-fx-font-size: 16px; -fx-text-fill: -vc-text; -fx-font-weight: bold;" />
                <Label fx:id="deadlineLabel" text="Due Date" style="-fx-font-size: 14px; -fx-text-fill: -vc-accent;" />
                <Label fx:id="latePolicyLabel" text="Late Allowed" style="-fx-font-size: 12px; -fx-text-fill: gray;" />
            </VBox>
        </HBox>

        <Separator />

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background-insets: 0;">
            <VBox spacing="20">
                <!-- Description Section -->
                <VBox spacing="8">
                    <Label text="Instructions" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -vc-text;" />
                    <Label fx:id="descriptionLabel" text="Description goes here..." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: -vc-text;" />
                </VBox>

                <!-- Submission Section -->
                <VBox spacing="12" style="-fx-border-color: lightgray; -fx-border-radius: 8; -fx-padding: 16; -fx-background-color: white; -fx-background-radius: 8;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="Your Work" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -vc-text;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="statusLabel" text="Not Submitted" style="-fx-font-size: 14px; -fx-text-fill: gray; -fx-font-weight: bold; -fx-padding: 4 8; -fx-background-color: #f0f0f0; -fx-background-radius: 12;" />
                    </HBox>
                    <Label fx:id="fileLabel" text="No file uploaded" style="-fx-font-style: italic; -fx-text-fill: gray;" />
                    <HBox spacing="16">
                        <Button fx:id="uploadBtn" text="Upload File" onAction="#handleUpload" style="-fx-background-color: -vc-primary; -fx-text-fill: white; -fx-padding: 8 16; -fx-font-weight: bold; -fx-background-radius: 4;" />
                        <Button fx:id="submitBtn" text="Turn In" onAction="#handleSubmit" style="-fx-background-color: -vc-accent; -fx-text-fill: white; -fx-padding: 8 16; -fx-font-weight: bold; -fx-background-radius: 4;" />
                        <Button fx:id="unsubmitBtn" text="Unsubmit" onAction="#handleUnsubmit" visible="false" managed="false" style="-fx-background-color: #d9534f; -fx-text-fill: white; -fx-padding: 8 16; -fx-background-radius: 4;" />
                    </HBox>
                </VBox>

                <!-- Comments Section -->
                <VBox spacing="12">
                    <Label text="Private Comments" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -vc-text;" />
                    <VBox fx:id="commentsBox" spacing="10" />
                    <HBox spacing="10">
                        <TextField fx:id="commentInput" promptText="Add a comment..." HBox.hgrow="ALWAYS" style="-fx-padding: 8;" />
                        <Button text="Post" onAction="#handleAddComment" style="-fx-background-color: -vc-secondary; -fx-text-fill: white; -fx-padding: 8 16;" />
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
        
        <HBox alignment="CENTER_RIGHT">
            <Button text="Close" onAction="#handleClose" style="-fx-background-color: lightgray; -fx-padding: 8 16; -fx-text-fill: black;" />
        </HBox>
    </VBox>
</StackPane>
