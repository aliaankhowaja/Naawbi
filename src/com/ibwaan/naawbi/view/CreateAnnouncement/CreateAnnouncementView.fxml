<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ibwaan.naawbi.controller.CreateAnnouncementController" spacing="16" prefWidth="600" prefHeight="500" styleClass="root-pane" stylesheets="@./CreateAnnouncementView.css">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    <Label text="Post Announcement" styleClass="modal-title" />
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Course:" styleClass="form-label" />
        <Label fx:id="courseNameLabel" text="[Loading...]" styleClass="form-value" HBox.hgrow="ALWAYS" />
    </HBox>
    <Separator />
    <VBox spacing="6">
        <Label text="Announcement Title" styleClass="form-label" />
        <TextField fx:id="titleField" promptText="Enter announcement title..." styleClass="form-input" prefHeight="40" />
    </VBox>
    <HBox spacing="8" alignment="CENTER_LEFT" styleClass="formatting-toolbar">
        <Button fx:id="boldBtn" text="B" styleClass="format-btn" onAction="#handleBold" prefWidth="40" prefHeight="36" />
        <Button fx:id="italicBtn" text="I" styleClass="format-btn" onAction="#handleItalic" prefWidth="40" prefHeight="36" />
        <Button fx:id="underlineBtn" text="U" styleClass="format-btn" onAction="#handleUnderline" prefWidth="40" prefHeight="36" />
        <Separator orientation="VERTICAL" />
        <Button fx:id="bulletBtn" text="•" styleClass="format-btn" onAction="#handleBulletList" prefWidth="40" prefHeight="36" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="HTML mode" styleClass="format-hint" />
    </HBox>
    <VBox spacing="6" VBox.vgrow="ALWAYS">
        <Label text="Announcement Content" styleClass="form-label" />
        <TextArea fx:id="contentArea" promptText="Enter announcement content here..." styleClass="form-textarea" wrapText="true" VBox.vgrow="ALWAYS" />
        <Label text="Supports: Bold, Italic, Underline, Lists" styleClass="form-hint" />
    </VBox>
    <VBox spacing="6">
        <Label text="Attachments (Optional)" styleClass="form-label" />
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Button fx:id="uploadBtn" text="+ Add File" styleClass="btn-secondary" onAction="#handleFileUpload" />
            <VBox fx:id="fileListContainer" spacing="4" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" styleClass="btn-cancel" onAction="#handleCancel" prefWidth="100" />
        <Button text="Post Announcement" styleClass="btn-primary" onAction="#handlePost" prefWidth="150" />
    </HBox>
</VBox>
